# FastAPI Backend Environment Variables
# Copy this to .env and fill in your actual values

# Google AI - Gemini API
GEMINI_API_KEY=

# OpenAI - Whisper API
OPENAI_API_KEY=

# Google Cloud - Drive API
GOOGLE_APPLICATION_CREDENTIALS=./gcloud_key.json

# JWT Secret - use any long random string
JWT_SECRET=

# Supabase Auth
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Database
DATABASE_URL=sqlite:///./data/classroom_emotions.db

# Camera RTSP stream URL
CLASSROOM_CAMERA_URL=rtsp://192.168.1.x/stream

# FastAPI deployment URL (used by frontend)
FASTAPI_BASE_URL=http://localhost:8000

# Deployment environment
ENVIRONMENT=development
